# =============================================================================
# AI 公众号 Ship Pipeline — 凭证模板
# =============================================================================
# 用法:复制本文件为 .env(本文件入 git,.env 不入 git)
#   PowerShell:  copy .env.example .env
# 然后逐项填入真实凭证。所有以 # 开头的行是注释。
# =============================================================================

# -----------------------------------------------------------------------------
# 微信公众号 API(必填,Step 8 推草稿用)
# -----------------------------------------------------------------------------
# 获取:微信公众号后台 → 设置与开发 → 基本配置 → AppID / AppSecret
WECHAT_APPID=wx_your_appid_here
WECHAT_SECRET=your_app_secret_here

# Cloudflare Worker 反向代理(作者自建实例,可替换为你自己的)
# 解决:微信 API 公共代理不稳定问题
WECHAT_API_BASE=https://mp-proxy-worker.dufengyun12.workers.dev

# -----------------------------------------------------------------------------
# 火山引擎方舟 Seedream(必填,封面 + 内文图)
# -----------------------------------------------------------------------------
# 获取:https://console.volcengine.com/ark/ → API Key 管理
VOLCENGINE_IMAGE_KEY=your_volcengine_ark_key_here

# -----------------------------------------------------------------------------
# Anthropic Claude API(必填,所有 skill 底层)
# -----------------------------------------------------------------------------
# 获取:https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# -----------------------------------------------------------------------------
# DeepSeek(选填,某些 lint 任务可用便宜模型)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# -----------------------------------------------------------------------------
# we-mp-rss Docker 容器(localhost:8001,公众号 feed)
# -----------------------------------------------------------------------------
# 容器登录 cookie(扫码后从 docker logs 拿,~80 小时有效需定期重抓)
WMP_USERNAME=your_wmp_username
WMP_PASSWORD=your_wmp_password

# -----------------------------------------------------------------------------
# 飞书 Lark(选填,数据飞轮 v0 用)
# -----------------------------------------------------------------------------
LARK_APP_ID=cli_your_app_id
LARK_APP_SECRET=your_lark_secret
LARK_FENGYUN_METRICS_BASE_URL=https://your.feishu.cn/base/xxx

# -----------------------------------------------------------------------------
# TikHub MCP(选填,小红书数据补充)
# -----------------------------------------------------------------------------
# 见 reference_tikhub_usage 备忘
TIKHUB_API_KEY=your_tikhub_key_here

# -----------------------------------------------------------------------------
# 其他(选填)
# -----------------------------------------------------------------------------
# Hugging Face Space RSSHub(已 DEPRECATED,改走本机 Docker,留作备选)
# HF_RSSHUB_URL=https://yourname-rsshub.hf.space

# Email-to-RSS(规划中,未启动)
# EMAIL_RSS_URL=https://yourdomain.com
